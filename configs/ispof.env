# Ispof environment file — sourced by the ispof.service unit.
# Edit and `systemctl restart ispof` to apply.

# Address to bind. Keep loopback for production behind a reverse proxy.
# Set to 0.0.0.0:2095 to expose directly (requires ISPOF_AUTH).
ISPOF_LISTEN=0.0.0.0:3000

# Log verbosity: debug | info | warn | error
ISPOF_LOG_LEVEL=info

# Basic auth credentials in user:password form. Leave empty to disable
# auth (only safe when ISPOF_LISTEN is loopback).
ISPOF_AUTH=admin:CHANGE_ME_BEFORE_DEPLOYING
