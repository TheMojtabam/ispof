{
  "_": "Minimal server config. Performance defaults are auto-adaptive — do",
  "__": "not set read_buffer / write_buffer / *_receive_window unless you",
  "___": "have a specific reason. See README for the full knob list.",

  "mode": "server",
  "transport": {
    "type": "udp"
  },
  "listen_port": 8080,
  "spoof": {
    "source_ip": "SERVER_SPOOF_IP",
    "peer_spoof_ip": "CLIENT_SPOOF_IP",
    "client_real_ip": "CLIENT_REAL_IP"
  },
  "crypto": {
    "private_key": "",
    "peer_public_key": ""
  },
  "obfuscation": {
    "enabled": true,
    "mode": "standard"
  },
  "security": {
    "block_private_targets": true
  },
  "logging": {
    "level": "info",
    "file": ""
  }
}
