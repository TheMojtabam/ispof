# -*- mode: ruby -*-
# vi: set ft=ruby :

#_QUICochet e2e test environment
#
# Two VMs on a v4+v6 dual-stack private network:
#   server  192.168.56.10 / fd99::10   — tunnel server + iperf3 server
#   client  192.168.56.11 / fd99::11   — tunnel client + iperf3 client (via SOCKS5)
#
# Spoofed IPs (fake, not assigned to any interface):
#   server spoof source v4: 10.99.0.10        v6: fd99::10:1
#   client spoof source v4: 10.99.0.11        v6: fd99::11:1
#
# Usage:
#   cd test/e2e
#   ./setup-keys.sh            # generate crypto keys (once)
#   vagrant up                 # create and provision VMs
#   ./deploy.sh                # rsync code, rebuild, restart services
#   ./switch-stack.sh v4|v6|dual  # swap the active spoof config
#   vagrant ssh client -c "sudo bash /vagrant/bench.sh"

SERVER_IP       = "192.168.56.10"
CLIENT_IP       = "192.168.56.11"
SERVER_SPOOF_IP = "10.99.0.10"
CLIENT_SPOOF_IP = "10.99.0.11"

# IPv6 ULA addresses (RFC 4193, fd99::/64) added on top of the v4
# private LAN by provision-common.sh. We do NOT spin up a second
# libvirt network for v6 — vagrant-libvirt 0.12.2 has a known bug
# computing v6 netmasks (calculates as v4) and crashes on
# `private_network, ip: <v6>`. Layering v6 onto the existing v4 NIC
# (same L2 segment) avoids the bug entirely and gives the same
# dual-stack reachability for the test scenarios.
SERVER_IPV6       = "fd99::10"
CLIENT_IPV6       = "fd99::11"
SERVER_SPOOF_IPV6 = "fd99::10:1"
CLIENT_SPOOF_IPV6 = "fd99::11:1"

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"

  config.vm.provider :libvirt do |lv|
    lv.memory = 4096
    lv.cpus   = 4
  end

  # Sync project root (two levels up from test/e2e) into /opt/quiccochet
  config.vm.synced_folder "../../", "/opt/quiccochet", type: "rsync",
    rsync__exclude: [".git/", "test/e2e/.vagrant/", "test/e2e/keys/"]

  # Sync this test dir for scripts and shared keys
  config.vm.synced_folder ".", "/vagrant", type: "rsync",
    rsync__exclude: [".vagrant/"]

  # ---------- server ----------
  config.vm.define "server", primary: false do |s|
    s.vm.hostname = "server"
    s.vm.network :private_network, ip: SERVER_IP

    s.vm.provision "shell", path: "provision-common.sh",
      env: { "VM_IPV6" => SERVER_IPV6 }
    s.vm.provision "shell", path: "provision-server.sh",
      env: {
        "SERVER_IP"         => SERVER_IP,
        "CLIENT_IP"         => CLIENT_IP,
        "SERVER_SPOOF_IP"   => SERVER_SPOOF_IP,
        "CLIENT_SPOOF_IP"   => CLIENT_SPOOF_IP,
        "SERVER_IPV6"       => SERVER_IPV6,
        "CLIENT_IPV6"       => CLIENT_IPV6,
        "SERVER_SPOOF_IPV6" => SERVER_SPOOF_IPV6,
        "CLIENT_SPOOF_IPV6" => CLIENT_SPOOF_IPV6,
      }
  end

  # ---------- client ----------
  config.vm.define "client", primary: true do |c|
    c.vm.hostname = "client"
    c.vm.network :private_network, ip: CLIENT_IP

    c.vm.provision "shell", path: "provision-common.sh",
      env: { "VM_IPV6" => CLIENT_IPV6 }
    c.vm.provision "shell", path: "provision-client.sh",
      env: {
        "SERVER_IP"         => SERVER_IP,
        "CLIENT_IP"         => CLIENT_IP,
        "SERVER_SPOOF_IP"   => SERVER_SPOOF_IP,
        "CLIENT_SPOOF_IP"   => CLIENT_SPOOF_IP,
        "SERVER_IPV6"       => SERVER_IPV6,
        "CLIENT_IPV6"       => CLIENT_IPV6,
        "SERVER_SPOOF_IPV6" => SERVER_SPOOF_IPV6,
        "CLIENT_SPOOF_IPV6" => CLIENT_SPOOF_IPV6,
      }
  end
end
